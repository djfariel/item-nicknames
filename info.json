{
  "name": "item-nicknames",
  "version": "1.0.0",
  "title": "Item Nicknames",
  "author": "djfariel",
  "factorio_version": "2.1",
  "description": "Adds hidden nickname search terms to item names.",
  "package": {
    "ignore": [
      ".git/**",
      ".gitignore",
      ".idea/**",
      ".vscode/**",
      ".editorconfig",
      "description.md",
      "faq.md",
      "gallery/**",
      "gallery/*.jpg",
      "gallery/*.jpeg",
      "**/*.zip",
      "Thumbs.db",
      ".DS_Store"
    ],
    "gallery": ["gallery/*.png"],
    "prune_gallery": true,
    "readme": "description.md",
    "faq": "faq.md",
    "sync_portal_details": true,
    "zipLocation": "outside"
  }
}
